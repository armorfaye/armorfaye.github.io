---
import BaseLayout from './BaseLayout.astro';

interface Props {
  data: {
    title: string;
    summary: string;
    date: Date;
    tags?: string[];
  };
}
const { data } = Astro.props;
const formatted = data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={data.title} description={data.summary} type="article">
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <a
      href="/blog"
      class="mb-8 inline-flex items-center gap-1.5 text-sm font-medium text-stone-500 transition-colors hover:text-accent-600 dark:text-stone-400 dark:hover:text-accent-400"
    >
      <span aria-hidden="true">&larr;</span> All posts
    </a>

    <header class="mb-10 border-b border-stone-200 pb-8 dark:border-stone-800">
      <time datetime={data.date.toISOString()} class="text-sm text-stone-500 dark:text-stone-500">
        {formatted}
      </time>
      <h1 class="mt-2 font-serif text-4xl leading-tight text-stone-900 dark:text-stone-100 sm:text-5xl">
        {data.title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-stone-600 dark:text-stone-400">
        {data.summary}
      </p>
      {
        data.tags && data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {data.tags.map((t) => (
              <span class="rounded-full bg-accent-500/10 px-3 py-1 text-xs font-medium text-accent-700 ring-1 ring-inset ring-accent-500/30 dark:text-accent-300">
                {t}
              </span>
            ))}
          </div>
        )
      }
    </header>

    <div class="prose-portfolio max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
