---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The page you're looking for doesn't exist.">
  <div class="mx-auto flex max-w-2xl flex-col items-center px-4 py-32 text-center sm:px-6">
    <p class="font-serif text-7xl text-accent-600 dark:text-accent-400">404</p>
    <h1 class="mt-4 font-serif text-3xl text-stone-900 dark:text-stone-100">
      This page wandered off.
    </h1>
    <p class="mt-3 text-stone-600 dark:text-stone-400">
      The page you're looking for doesn't exist or may have moved.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="rounded-md bg-accent-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent-500"
      >
        Back home
      </a>
      <a
        href="/projects"
        class="rounded-md px-5 py-2.5 text-sm font-semibold text-stone-800 ring-1 ring-inset ring-stone-300 transition-colors hover:bg-stone-200/60 dark:text-stone-100 dark:ring-stone-700 dark:hover:bg-stone-800"
      >
        View projects
      </a>
    </div>
  </div>
</BaseLayout>
