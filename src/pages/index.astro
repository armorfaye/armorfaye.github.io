---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import DocumentCard from '../components/DocumentCard.astro';
import { skillGroups } from '../data/skills';
import { experienceHighlights } from '../data/experience';
import { documents } from '../data/documents';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const featuredDocs = documents.filter((d) => d.featured).slice(0, 3);
---

<BaseLayout>
  <Hero />

  <!-- Featured projects -->
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <SectionHeader
      eyebrow="Selected work"
      title="Featured projects"
      subtitle="A few projects that best capture how I think about research and engineering."
      link={{ label: 'All projects', href: '/projects' }}
    />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        featured.map((p) => (
          <ProjectCard
            slug={p.id}
            title={p.data.title}
            summary={p.data.summary}
            categories={p.data.categories}
            tags={p.data.tags}
            role={p.data.role}
            dates={p.data.dates}
            thumbnail={p.data.thumbnail}
            links={p.data.links}
          />
        ))
      }
    </div>
  </section>

  <!-- Experience highlights -->
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <SectionHeader
      eyebrow="Research & industry"
      title="Selected highlights"
      subtitle="Where I've done research and the recognition that has come with it."
      link={{ label: 'Full experience', href: '/experience' }}
    />
    <ul class="space-y-8 border-l border-stone-200 pl-2 dark:border-stone-800">
      {experienceHighlights.map((entry) => <ExperienceItem entry={entry} />)}
    </ul>
  </section>

  <!-- Skills -->
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <SectionHeader eyebrow="Toolkit" title="Technical stack" />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        skillGroups.map((group) => (
          <div class="rounded-xl border border-stone-200 bg-white p-5 dark:border-stone-800 dark:bg-stone-900/60">
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-accent-700 dark:text-accent-400">
              {group.label}
            </h3>
            <ul class="space-y-1.5 text-sm text-stone-600 dark:text-stone-400">
              {group.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Recent writing / documents -->
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <SectionHeader
      eyebrow="Reading"
      title="Selected documents"
      subtitle="Papers, posters, and reports from my research."
      link={{ label: 'All writing', href: '/writing' }}
    />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featuredDocs.map((doc) => <DocumentCard doc={doc} />)}
    </div>
  </section>
</BaseLayout>
