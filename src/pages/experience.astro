---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import { experienceSections } from '../data/experience';

// Hide sections with no entries (e.g. an empty Leadership placeholder).
const sections = experienceSections.filter((s) => s.entries.length > 0);
---

<BaseLayout
  title="Experience"
  description="Research, industry, education, programs, and awards of Jiayu (Jerry) Liu."
>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 sm:py-16">
    <SectionHeader
      eyebrow="Timeline"
      title="Experience"
      subtitle="Research, industry, education, and the programs and awards along the way."
    />

    <div class="space-y-14">
      {
        sections.map((section) => (
          <section>
            <h2 class="mb-6 text-sm font-semibold uppercase tracking-widest text-accent-700 dark:text-accent-400">
              {section.title}
            </h2>
            <ul class="space-y-8 border-l border-stone-200 dark:border-stone-800">
              {section.entries.map((entry) => (
                <ExperienceItem entry={entry} />
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
