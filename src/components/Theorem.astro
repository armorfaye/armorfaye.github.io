---
// Styled theorem/proof/definition block for math project pages (used in MDX).
interface Props {
  label?: string;
  // 'theorem' (accent) or 'proof' (muted).
  kind?: 'theorem' | 'proof';
}
const { label = 'Theorem', kind = 'theorem' } = Astro.props;
---

<div
  class:list={[
    'my-6 rounded-lg border-l-2 p-4',
    kind === 'proof'
      ? 'border-stone-400 bg-stone-100/60 dark:bg-stone-900/50'
      : 'border-accent-500 bg-accent-500/5',
  ]}
>
  <p
    class:list={[
      'mb-1 text-sm font-semibold uppercase tracking-wide',
      kind === 'proof'
        ? 'text-stone-500 dark:text-stone-400'
        : 'text-accent-700 dark:text-accent-400',
    ]}
  >
    {label}
  </p>
  <div class="text-stone-700 dark:text-stone-300 [&_p]:my-0">
    <slot />
  </div>
</div>
