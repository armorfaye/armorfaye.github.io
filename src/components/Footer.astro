---
import { site, socials } from '../data/site';
import Icon from './Icon.astro';

const year = new Date().getFullYear();
const links = [
  { name: 'github', label: 'GitHub', url: socials.github },
  { name: 'linkedin', label: 'LinkedIn', url: socials.linkedin },
  { name: 'mail', label: 'Email', url: socials.email },
  socials.scholar
    ? { name: 'scholar', label: 'Google Scholar', url: socials.scholar }
    : null,
].filter(Boolean) as { name: string; label: string; url: string }[];

const socialBtnClass =
  'inline-flex h-11 w-11 items-center justify-center rounded-full text-stone-500 ring-1 ring-inset ring-stone-200 transition-all duration-200 hover:-translate-y-0.5 hover:text-accent-600 hover:ring-accent-400/60 dark:text-stone-400 dark:ring-stone-700/80 dark:hover:text-accent-400 dark:hover:ring-accent-500/50';
---

<footer id="contact" class="relative mt-24 border-t border-stone-200/70 dark:border-stone-800/70">
  <!-- Faint accent glow, kept very subtle for a minimal feel. -->
  <div
    class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-40 bg-gradient-to-b from-accent-500/[0.03] to-transparent dark:from-accent-400/[0.05]"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <div class="flex flex-col items-start justify-between gap-10 sm:flex-row sm:items-end">
      <div class="max-w-md">
        <p
          class="mb-3 text-xs font-medium uppercase tracking-[0.2em] text-accent-600 dark:text-accent-400"
        >
          Get in touch
        </p>
        <p
          class="font-serif text-4xl tracking-tight text-stone-900 dark:text-stone-100"
        >
          Let&rsquo;s connect
        </p>
        <p class="mt-4 text-base leading-relaxed text-stone-600 dark:text-stone-400">
          Reach me at{' '}
          <a
            href={socials.email}
            class="font-medium text-accent-700 underline decoration-accent-400/50 underline-offset-[3px] transition-colors hover:text-accent-500 hover:decoration-accent-500 dark:text-accent-400 dark:decoration-accent-500/40 dark:hover:text-accent-300"
            >{site.email}</a
          >.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        {
          links.map((link) => (
            <a
              href={link.url}
              target={link.url.startsWith('http') ? '_blank' : undefined}
              rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
              class={socialBtnClass}
              aria-label={link.label}
            >
              <Icon name={link.name} class="h-5 w-5" />
            </a>
          ))
        }
        <a
          href={site.resume}
          class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium text-stone-500 ring-1 ring-inset ring-stone-200 transition-all duration-200 hover:-translate-y-0.5 hover:text-accent-600 hover:ring-accent-400/60 dark:text-stone-400 dark:ring-stone-700/80 dark:hover:text-accent-400 dark:hover:ring-accent-500/50"
        >
          <Icon name="resume" class="h-4 w-4" /> Resume
        </a>
      </div>
    </div>

    <p class="mt-12 border-t border-stone-200/60 pt-6 text-sm text-stone-500 dark:border-stone-800/60 dark:text-stone-500">
      &copy; {year} {site.name}. Built with Astro, TypeScript, and Tailwind CSS.
    </p>
  </div>
</footer>
