---
import { site } from '../data/site';
import Icon from './Icon.astro';
---

<section class="relative overflow-hidden">
  <!-- Subtle dotted grid, hero only. -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.4] dark:opacity-[0.25]"
    style="background-image: radial-gradient(currentColor 1px, transparent 1px); background-size: 22px 22px; color: rgb(120 113 108 / 0.35); mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black, transparent);"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-5xl px-4 pb-16 pt-20 sm:px-6 sm:pt-28">
    <div class="grid items-center gap-10 lg:grid-cols-[1fr_auto] lg:gap-14">
      <div>
        <h1 class="font-serif text-5xl leading-[1.05] text-stone-900 dark:text-stone-100 sm:text-7xl">
          {site.name}
        </h1>
        <p class="mt-4 text-xl text-stone-600 dark:text-stone-400 sm:text-2xl">
          {site.tagline}
        </p>

        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-stone-600 dark:text-stone-400">
          {site.intro} I work at the intersection of <strong
            class="font-semibold text-stone-800 dark:text-stone-200">AI systems</strong
          >, <strong class="font-semibold text-stone-800 dark:text-stone-200">machine learning</strong>,
          <strong class="font-semibold text-stone-800 dark:text-stone-200">mathematical research</strong
          >, <strong class="font-semibold text-stone-800 dark:text-stone-200">assistive technology</strong
          >, and <strong class="font-semibold text-stone-800 dark:text-stone-200"
            >scientific computing</strong
          >&mdash;building systems that turn research ideas into things that work.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="/projects"
            class="inline-flex items-center gap-2 rounded-md bg-accent-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent-500"
          >
            View Projects <Icon name="arrow" class="h-4 w-4" />
          </a>
          <a
            href={site.resume}
            class="inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold text-stone-800 ring-1 ring-inset ring-stone-300 transition-colors hover:bg-stone-200/60 dark:text-stone-100 dark:ring-stone-700 dark:hover:bg-stone-800"
          >
            <Icon name="resume" class="h-4 w-4" /> Resume
          </a>
          <a
            href="#contact"
            class="inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold text-stone-800 ring-1 ring-inset ring-stone-300 transition-colors hover:bg-stone-200/60 dark:text-stone-100 dark:ring-stone-700 dark:hover:bg-stone-800"
          >
            <Icon name="mail" class="h-4 w-4" /> Contact
          </a>
        </div>
      </div>

      <div class="mx-auto w-full max-w-xs shrink-0 lg:max-w-none lg:w-72 xl:w-80">
        <div
          class="overflow-hidden rounded-2xl border border-stone-200 shadow-xl shadow-stone-900/10 ring-1 ring-stone-200/80 dark:border-stone-700 dark:shadow-black/30 dark:ring-stone-700"
        >
          <img
            src={site.profile}
            alt="Jiayu (Jerry) Liu"
            width="640"
            height="640"
            class="aspect-square w-full object-cover object-top"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </div>
</section>
