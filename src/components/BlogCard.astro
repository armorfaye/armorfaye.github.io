---
interface Props {
  slug: string;
  title: string;
  summary: string;
  date: Date;
  tags?: string[];
}
const { slug, title, summary, date, tags = [] } = Astro.props;
const href = `/blog/${slug}`;
const formatted = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article
  class="group flex flex-col rounded-xl border border-stone-200 bg-white p-5 transition-all duration-300 hover:-translate-y-1 hover:border-accent-400/60 hover:shadow-lg hover:shadow-accent-500/5 dark:border-stone-800 dark:bg-stone-900/60"
>
  <time datetime={date.toISOString()} class="text-xs font-medium text-stone-500 dark:text-stone-500">
    {formatted}
  </time>

  <h3 class="mt-2 font-serif text-xl text-stone-900 dark:text-stone-100">
    <a href={href} class="transition-colors hover:text-accent-600 dark:hover:text-accent-400">
      {title}
    </a>
  </h3>

  <p class="mt-2 flex-1 text-sm leading-relaxed text-stone-600 dark:text-stone-400">
    {summary}
  </p>

  {
    tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5 border-t border-stone-100 pt-4 dark:border-stone-800">
        {tags.map((t) => (
          <span class="rounded-full bg-stone-100 px-2.5 py-0.5 text-xs text-stone-600 dark:bg-stone-800 dark:text-stone-400">
            {t}
          </span>
        ))}
      </div>
    )
  }

  <a
    href={href}
    class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-accent-700 transition-colors hover:text-accent-500 dark:text-accent-400"
  >
    Read post <span aria-hidden="true">&rarr;</span>
  </a>
</article>
