const d = paths[name] ?? paths.site;
// Stroke-style icons need fill:none + strokeWidth; the rest are filled paths.
const stroked = ['arrow', 'sun', 'menu', 'close'].includes(name);
---

{
  stroked ? (
    <svg
      class={className}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d={d} />
    </svg>
  ) : (
    <svg class={className} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d={d} />
    </svg>
  )
}
