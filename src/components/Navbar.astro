---
import { navLinks, site } from '../data/site';
import ThemeToggle from './ThemeToggle.astro';
import Icon from './Icon.astro';

// Normalize the current path so "/projects/foo" still highlights "Projects".
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header
  class="sticky top-0 z-40 border-b border-stone-200/70 bg-stone-50/80 backdrop-blur-md dark:border-stone-800/70 dark:bg-stone-950/80"
>
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between px-4 sm:px-6">
    <a
      href="/"
      class="font-serif text-xl text-stone-900 transition-colors hover:text-accent-600 dark:text-stone-100 dark:hover:text-accent-400"
    >
      {site.shortName}
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <ul class="hidden items-center gap-1 sm:flex">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? 'page' : undefined}
                class:list={[
                  'rounded-md px-3 py-2 text-sm font-medium transition-colors',
                  isActive(link.href)
                    ? 'text-accent-700 dark:text-accent-400'
                    : 'text-stone-600 hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href={site.resume}
            class="ml-1 rounded-md bg-accent-600 px-3 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-500"
          >
            Resume
          </a>
        </li>
      </ul>

      <ThemeToggle />

      <button
        id="menu-button"
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md text-stone-600 ring-1 ring-inset ring-stone-300/70 hover:bg-stone-200/60 dark:text-stone-300 dark:ring-stone-700 dark:hover:bg-stone-800 sm:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span id="menu-open-icon"><Icon name="menu" class="h-5 w-5" /></span>
        <span id="menu-close-icon" class="hidden"><Icon name="close" class="h-5 w-5" /></span>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-stone-200/70 dark:border-stone-800/70 sm:hidden">
    <ul class="space-y-1 px-4 py-3">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={[
                'block rounded-md px-3 py-2 text-base font-medium',
                isActive(link.href)
                  ? 'bg-accent-500/10 text-accent-700 dark:text-accent-300'
                  : 'text-stone-700 hover:bg-stone-200/60 dark:text-stone-300 dark:hover:bg-stone-800',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href={site.resume}
          class="block rounded-md bg-accent-600 px-3 py-2 text-base font-medium text-white hover:bg-accent-500"
        >
          Resume
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const button = document.getElementById('menu-button');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  button?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    button.setAttribute('aria-expanded', String(isOpen));
    openIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
  });
</script>
